<style>
  .y2k-marquee-container {
    width: 100%;
    overflow: hidden;
    background: #000;
    color: #fff;
    padding: 12px 0;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #222;
  }
  .y2k-marquee {
    display: flex;
    white-space: nowrap;
    animation: y2k-scroll 40s linear infinite;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 1.3rem;
  }
  .y2k-marquee-item {
    display: flex;
    align-items: center;
    padding: 0;
  }
  .y2k-symbol {
    font-size: 1.4rem;
    margin: 0 3rem;
    animation: color-pulse 3s infinite;
  }
  @keyframes y2k-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes color-pulse {
    0% { color: #ff00ff; } /* Neon Pink */
    33% { color: #00ffff; } /* Cyan */
    66% { color: #39ff14; } /* Neon Green */
    100% { color: #ff00ff; }
  }
</style>

<div class="y2k-marquee-container">
  <div class="y2k-marquee">
    {%- for i in (1..10) -%}
      <div class="y2k-marquee-item">
        ARCHIVE COLLECTION <span class="y2k-symbol">✦</span> NO RESTOCKS <span class="y2k-symbol">✚</span> LIMITED DROP <span class="y2k-symbol">✦</span> SECURE YOURS NOW <span class="y2k-symbol">✚</span>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "class": "announcement-bar-section",
  "settings": [],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name"
    }
  ]
}
{% endschema %}
